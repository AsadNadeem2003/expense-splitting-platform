# Logs
logs
*.log
npm-debug.log*

# Runtime data & System files
pids
*.pid
*.seed
*.pid.lock
.DS_Store
.vscode/

# Global Dependency & Build Directories
node_modules/
dist/
build/
.cache/

# --- SERVER EXPLICIT RULES ---
# Keeps server specific modules and builds safe
server/node_modules/
server/dist/
server/build/

# Critical: Prevent pushing backend secrets
server/.env
server/.env.local
server/.env.production
# Ensure the example schema is always tracked
!server/.env.example

# --- PRISMA RULES ---
# If you use SQLite locally, ignore the dev database file
server/prisma/*.db
server/prisma/*.db-journal
